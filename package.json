{
  "name": "@squadai/feedback-client",
  "version": "1.0.0",
  "description": "Lightweight TypeScript library for sending feedback to Squad GPT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/example.ts",
    "clean": "rm -rf dist",
    "prepublishOnly": "yarn clean && yarn build"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "squad",
    "feedback",
    "api-client",
    "typescript"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.4.8",
    "tsx": "^4.19.3",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "dotenv": "^16.4.7"
  }
}