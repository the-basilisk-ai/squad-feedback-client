# Squad API Configuration

# Your Squad API key (required)
# Get this from your Squad dashboard
SQUAD_API_KEY=your-api-key-here

# Optional: Override the default API base URL
# Defaults to https://api.meetsquad.ai if not set
# Development: https://dev.api.meetsquad.ai
# Staging: https://uat.api.meetsquad.ai
# Production: https://api.meetsquad.ai
# SQUAD_BASE_URL=https://api.meetsquad.ai
